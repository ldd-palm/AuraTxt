{
  "id": "default-openai",
  "description": "Fallback for unrecognized OpenAI-compatible models - send nothing special",
  "match": {
    "name_patterns": ["*"]
  },
  "priority": -100,
  "adapter_compatibility": ["openai_compatible"],
  "thinking": null,
  "strip_patterns": [],
  "capabilities": {
    "streaming": true,
    "system_prompt": true,
    "multi_turn": true
  },
  "recommended_params": {
    "temperature": 0.7,
    "top_p": 1.0,
    "max_tokens": 4096
  }
}
