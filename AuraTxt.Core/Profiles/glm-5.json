{
  "id": "glm-5",
  "description": "Zhipu GLM-5 / GLM-5.1 / GLM-4.7 - dual-key disable for safety",
  "match": {
    "name_patterns": [
      "*glm-5*",
      "*glm-4.7*",
      "z-ai/glm-*"
    ]
  },
  "priority": 90,
  "adapter_compatibility": ["openai_compatible"],
  "thinking": {
    "location": "chat_template_kwargs",
    "modes": {
      "disable": { "thinking": false, "enable_thinking": false },
      "enable_high": { "thinking": true }
    }
  },
  "strip_patterns": [],
  "capabilities": {
    "streaming": true,
    "system_prompt": true,
    "multi_turn": true
  },
  "recommended_params": {
    "temperature": 0.3,
    "top_p": 1.0,
    "max_tokens": 4096
  }
}
