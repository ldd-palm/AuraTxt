{
  "id": "default-gemini",
  "description": "Fallback for unrecognized Gemini-native endpoint models - send nothing special",
  "match": {
    "name_patterns": ["*"]
  },
  "priority": -100,
  "adapter_compatibility": ["gemini_native"],
  "thinking": null,
  "strip_patterns": [],
  "capabilities": {
    "streaming": true,
    "system_prompt": true,
    "multi_turn": true
  },
  "recommended_params": {
    "temperature": 0.7,
    "top_p": 1.0,
    "max_tokens": 4096
  }
}
