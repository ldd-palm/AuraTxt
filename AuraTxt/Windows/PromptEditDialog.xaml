<Window x:Class="AuraTxt.Windows.PromptEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Prompt" Width="480" Height="280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceElevated}"
        Foreground="{DynamicResource TextPrimary}">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBox x:Name="PromptBox" Grid.Row="0"
             Background="{DynamicResource InputFill}"
             Foreground="{DynamicResource TextPrimary}"
             BorderBrush="{DynamicResource InputStroke}"
             AcceptsReturn="True" TextWrapping="Wrap"
             FontFamily="Consolas" FontSize="13" Padding="8"
             VerticalScrollBarVisibility="Auto"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button x:Name="CancelBtn" Content="Cancel" Width="70" Height="28" Margin="0,0,8,0" Click="Cancel_Click"/>
      <Button x:Name="OkBtn"     Content="Generate" Width="80" Height="28"
              Background="{DynamicResource Accent}" Foreground="White"
              BorderBrush="Transparent"
              Click="OK_Click"/>
    </StackPanel>
  </Grid>
</Window>
