<Window x:Class="AuraTxt.Windows.InteractiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="False"
        Width="520" Height="420" ResizeMode="CanResize"
        PreviewKeyDown="Window_PreviewKeyDown">
  <Border Background="{DynamicResource SurfaceElevated}" CornerRadius="8" Margin="8">
    <Border.Effect>
      <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                        Opacity="{DynamicResource ShadowOpacity}"
                        Color="Black"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="36"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Border Grid.Row="0" Background="{DynamicResource TitleBarFill}"
              CornerRadius="8,8,0,0"
              MouseLeftButtonDown="TitleBar_MouseDown">
        <Grid Margin="10,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Width="12" Height="12"
                  Background="{DynamicResource CloseBtn}"
                  BorderBrush="Transparent"
                  Template="{StaticResource CircleButtonTemplate}"
                  Click="CloseBtn_Click"/>
          <DockPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0" LastChildFill="True">
            <Image x:Name="TitleIcon" DockPanel.Dock="Left" Width="14" Height="14"
                   Margin="0,0,5,0" VerticalAlignment="Center" Visibility="Collapsed"/>
            <TextBlock x:Name="TitleLabel"
                       Foreground="{DynamicResource TextSecondary}" FontSize="13"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
          </DockPanel>
          <ComboBox Grid.Column="2" x:Name="ModelPicker" Margin="4,0" Height="22" MinWidth="100"
                    Background="{DynamicResource PickerBgFill}" Foreground="{DynamicResource PickerFgFill}"
                    FontSize="12" FontWeight="SemiBold"
                    BorderBrush="{DynamicResource CmbStroke}" VerticalContentAlignment="Center"
                    SelectionChanged="ModelPicker_SelectionChanged">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}"
                           Foreground="{DynamicResource TextPrimary}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
            <Button Width="26" Height="26" Style="{StaticResource IconBtnStyle}"
                    ToolTip="Edit Prompt (P)" Click="EditBtn_Click" Content="✏️" Margin="4,0,0,0"/>
            <Button Width="26" Height="26" Style="{StaticResource IconBtnStyle}"
                    ToolTip="Regenerate (R)" Click="RegenBtn_Click" Content="🔄" Margin="4,0,0,0"/>
            <Button x:Name="PinBtn" Width="26" Height="26" Style="{StaticResource IconBtnStyle}"
                    ToolTip="Pin Window (T)" Click="PinBtn_Click" Content="📌" Margin="4,0,0,0" Opacity="0.45"/>
            <Button Width="26" Height="26" Background="{DynamicResource CopyBtn}"
                    BorderBrush="Transparent"
                    Foreground="White" ToolTip="Copy All (C)" Click="CopyBtn_Click"
                    Content="📋" Margin="4,0,0,0"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- User input -->
      <Border Grid.Row="1" Background="{DynamicResource UserInputFill}"
              BorderBrush="{DynamicResource UserInputStroke}" BorderThickness="0,0,0,1">
        <Grid Margin="12,8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="Input" Foreground="{DynamicResource TextTertiary}"
                     FontSize="14" Margin="0,0,0,4"/>
          <TextBox x:Name="UserInput" Grid.Row="1"
                   Background="{DynamicResource InputFill}" Foreground="{DynamicResource TextPrimary}"
                   BorderBrush="{DynamicResource InputStroke}"
                   AcceptsReturn="True" TextWrapping="Wrap" Padding="8"
                   VerticalScrollBarVisibility="Auto"
                   PreviewKeyDown="UserInput_KeyDown"/>
        </Grid>
      </Border>

      <!-- AI result -->
      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
        <Grid Margin="12,8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="Result" Foreground="{DynamicResource TextTertiary}"
                     FontSize="14" Margin="0,0,0,4"/>
          <TextBox x:Name="ResultText" Grid.Row="1"
                   Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                   IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                   FontSize="13"/>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>
