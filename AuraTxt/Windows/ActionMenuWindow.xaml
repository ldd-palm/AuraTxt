<Window x:Class="AuraTxt.Windows.ActionMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="Manual"
        Topmost="True" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" ShowActivated="False">

  <!-- Double-layer shadow: outer ambient (large blur, no offset) + inner directional -->
  <Border CornerRadius="8">
    <Border.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.08" Color="Black"/>
    </Border.Effect>
    <Border Background="{DynamicResource MenuSurfaceFill}"
            BorderBrush="{DynamicResource SurfaceStroke}"
            BorderThickness="1"
            CornerRadius="8" Padding="6,4">
      <Border.Effect>
        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.14" Color="Black"/>
      </Border.Effect>
      <StackPanel x:Name="IconPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
    </Border>
  </Border>
</Window>
